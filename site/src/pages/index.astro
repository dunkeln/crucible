---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";

const loop = [
  ["attempt", "Codex changes the project."],
  ["proof", "Crucible runs the check."],
  ["reward", "The result becomes signal."]
];

const architecture = [
  ["Codex chooses.", "A recipe, a seam, a next move."],
  ["Crucible writes.", "The repeatable shape around the work."],
  ["Verifier decides.", "Only checked behavior moves forward."]
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Crucible is a Codex plugin for turning verified work into reusable learning signal." />
    <title>Crucible</title>
  </head>
  <body>
    <nav class="nav">
      <div class="shell nav-inner">
        <a class="brand" href="/">
          <img src="/logo.png" alt="" />
          <span>Crucible</span>
        </a>
        <a class="nav-link" href="https://github.com/dunkeln/crucible">GitHub</a>
      </div>
    </nav>

    <main>
      <section class="shell hero">
        <header class="hero-copy">
          <h1>Make Codex learn from work it can prove.</h1>
          <p>
            Crucible is a Codex plugin for work that has to survive checks. Codex selects the recipe. Crucible writes the artifact. The verifier decides what is worth keeping.
          </p>
        </header>

        <figure class="proof-card" aria-label="Crucible benchmark">
          <img src="/benchmark-crucible-red.svg" alt="Crucible benchmark showing lower fresh input and billable proxy than raw Codex." />
        </figure>
      </section>

      <section id="install" class="section install-section">
        <div class="shell install">
          <header>
            <h2>Install it where Codex already works.</h2>
            <code>codex plugin marketplace add dunkeln/crucible</code>
          </header>
          <figure class="marketplace-shot" aria-label="Crucible plugin marketplace page">
            <img src="/marketplace.png" alt="Crucible installed in the Codex plugin marketplace." />
          </figure>
        </div>
      </section>

      <section class="section loop-section">
        <div class="shell loop-grid">
          <header class="loop-copy">
            <h2>Crucible turns checked work into reusable signal.</h2>
            <p>Every run leaves a trail: what changed, what proved it, and what is worth carrying forward. That is loop engineering.</p>
          </header>
          <ol class="loop-stack" aria-label="Crucible loop">
            {loop.map(([title, body]) => (
              <li class="loop-row">
                <strong>{title}</strong>
                <span>{body}</span>
              </li>
            ))}
            <li class="promote-box">promote the pattern</li>
          </ol>
        </div>
      </section>

      <section id="proof" class="section architecture-section">
        <div class="shell architecture">
          <h2 class="codex-heading">
            <img src="/codex.svg" alt="" />
            <span>Codex gets a stable factory.</span>
          </h2>
          <ul class="architecture-grid" aria-label="Crucible operating model">
            {architecture.map(([title, body]) => (
              <li>
                <strong>{title}</strong>
                <p>{body}</p>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section class="section numbers-section">
        <div class="shell numbers">
          <header>
            <h2>The cost story appears on the second turn.</h2>
            <p>
              Same loose follow-up task. Same model. One arm gets a plain folder. One arm gets a locked pack with evidence already in place.
            </p>
          </header>
          <dl class="numbers-list" aria-label="Benchmark summary">
            <div><dt>-54%</dt><dd>fresh input</dd></div>
            <div><dt>-50%</dt><dd>billable proxy</dd></div>
            <div><dt>100%</dt><dd>verifier pass</dd></div>
          </dl>
        </div>
      </section>
    </main>
    <Analytics />
  </body>
</html>
