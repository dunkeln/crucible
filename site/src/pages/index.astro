---
import "../styles/global.css";

const loop = [
  ["attempt", "Codex changes the work."],
  ["proof", "The verifier decides."],
  ["reward", "Evidence becomes signal."]
];

const architecture = [
  ["Codex chooses.", "The plugin selects the recipe and the small project edge."],
  ["Crucible writes.", "The harness creates the repeatable artifact shape."],
  ["Verifier decides.", "Only checked behavior moves forward."]
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Crucible is a Codex plugin for turning verified work into reusable learning signal." />
    <title>Crucible</title>
  </head>
  <body>
    <nav class="nav">
      <div class="shell nav-inner">
        <a class="brand" href="/">
          <img src="/logo.png" alt="" />
          <span>Crucible</span>
        </a>
        <a class="nav-link" href="https://github.com/dunkeln/crucible">GitHub</a>
      </div>
    </nav>

    <main>
      <section class="shell hero">
        <div class="hero-copy">
          <h1>Make Codex learn from work it can prove.</h1>
          <p>
            Crucible is a Codex plugin for RLVR workflows. Codex selects the recipe. Crucible writes the artifact. The verifier decides what survives.
          </p>
          <div class="hero-actions" aria-label="Primary actions">
            <a class="button" href="#install">Install the plugin</a>
            <a class="button secondary" href="#proof">See the proof</a>
          </div>
        </div>

        <div class="proof-card" aria-label="Crucible benchmark">
          <img src="/benchmark-crucible-red.svg" alt="Crucible benchmark showing lower fresh input and billable proxy than raw Codex." />
        </div>
      </section>

      <section class="section loop-section">
        <div class="shell loop-grid">
          <div>
            <h2>One loop. One proof. One promoted pattern.</h2>
          </div>
          <div class="loop-stack">
            {loop.map(([title, body]) => (
              <div class="loop-row">
                <strong>{title}</strong>
                <span>{body}</span>
              </div>
            ))}
            <div class="promote-box">promote the pattern</div>
          </div>
        </div>
      </section>

      <section id="proof" class="section architecture-section">
        <div class="shell architecture">
          <h2>Codex gets a stable factory.</h2>
          <div class="architecture-grid">
            {architecture.map(([title, body]) => (
              <article>
                <strong>{title}</strong>
                <p>{body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section numbers-section">
        <div class="shell numbers">
          <div>
            <h2>The cost story appears on the second turn.</h2>
            <p>
              Same loose follow-up task. Same model. One arm gets a plain folder. One arm gets a locked Crucible pack with failing evidence and a next brief.
            </p>
          </div>
          <div class="numbers-list" aria-label="Benchmark summary">
            <div><strong>-54%</strong><span>fresh input</span></div>
            <div><strong>-50%</strong><span>billable proxy</span></div>
            <div><strong>100%</strong><span>verifier pass</span></div>
          </div>
        </div>
      </section>

      <section id="install" class="section install-section">
        <div class="shell install">
          <div>
            <h2>Install it where the work happens.</h2>
            <p>Marketplace install. Recipe selection. Deterministic generation. Verified signal.</p>
          </div>
          <code>codex plugin marketplace add dunkeln/crucible</code>
        </div>
      </section>
    </main>
  </body>
</html>
